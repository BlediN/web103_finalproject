{
  "name": "server",
  "version": "1.0.0",
  "description": "LayoffLens backend server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server start",
    "dev:client": "npm --prefix client run dev",
    "start": "npm --prefix server start",
    "reset": "npm --prefix server run reset",
    "seed": "npm --prefix server run seed"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "nodemon": "^3.1.10",
    "pg": "^8.13.1",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
